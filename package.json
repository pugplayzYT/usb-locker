{
  "name": "usb-locker",
  "version": "1.3.0",
  "description": "Encrypt files with your USB drive as the only key — AES-256-GCM CLI tool",
  "bin": {
    "usblocker": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prepare": "husky",
    "bundle:win": "pkg dist/index.js --target node18-win-x64 --output bin/usblocker-win.exe",
    "bundle:linux": "pkg dist/index.js --target node18-linux-x64 --output bin/usblocker-linux",
    "bundle:mac": "pkg dist/index.js --target node18-macos-x64 --output bin/usblocker-macos",
    "bundle": "npm run build && npm run bundle:win && npm run bundle:linux && npm run bundle:mac"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "bin"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "usb",
    "encryption",
    "aes-256-gcm",
    "cli",
    "security",
    "file-encryption"
  ],
  "license": "MIT"
}
